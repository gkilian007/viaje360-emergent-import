{
  "framework": "nextjs",
  "functions": {
    "src/app/api/itinerary/generate/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/itinerary/adapt/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/chat/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/dispatch-notifications/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/proactive/evaluate/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/cron/process-notifications/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/dispatch-notifications?context=morning",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/dispatch-notifications?context=evening",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/dispatch-notifications?context=postday",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/process-notifications",
      "schedule": "*/5 * * * *"
    }
  ]
}
